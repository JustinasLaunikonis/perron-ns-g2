{
  "name": "perron-ns-g2",
  "private": true,
  "version": "0.1.4",
  "type": "module",
  "description": "Glanceable NS (Dutch Railways) departures for Even Realities G2 — Even Hub app.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "qr": "evenhub qr --http",
    "pack": "npm run build && evenhub pack app.json dist -o perron-ns.ehpk",
    "simulate": "evenhub-simulator http://localhost:5173",
    "simulate:auto": "evenhub-simulator http://localhost:5173 --automation-port 9898"
  },
  "dependencies": {
    "@evenrealities/even_hub_sdk": "^0.0.11"
  },
  "devDependencies": {
    "@evenrealities/evenhub-cli": "^0.1.12",
    "@evenrealities/evenhub-simulator": "^0.7.2",
    "typescript": "^5.7.0",
    "vite": "^5.4.0",
    "vitest": "^4.1.9"
  }
}
